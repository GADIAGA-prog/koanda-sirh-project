# Copier en .env et adapter pour la production
# Base de données — SQLite par défaut, PostgreSQL recommandé en production :
# DATABASE_URL=postgresql+psycopg2://koanda:motdepasse@localhost:5432/koanda_sirh
DATABASE_URL=sqlite:///./koanda_sirh.db

# Clé de signature des jetons JWT — OBLIGATOIRE à changer en production
SECRET_KEY=change-moi-avec-une-cle-aleatoire-longue

ACCESS_TOKEN_EXPIRE_MINUTES=480

# Mot de passe des comptes de démonstration générés au premier démarrage
DEMO_PASSWORD=koanda2026

# Origines autorisées pour le front-end (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
